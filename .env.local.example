# Vercel Postgres — automatically injected by Vercel when you link a Postgres
# database to the project (Storage → Postgres → Connect Project). For local
# development, copy the POSTGRES_URL value from Vercel into .env.local.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Basic auth credentials for /admin/acceptances.
# If either is unset, the admin route returns 503.
ADMIN_USER=
ADMIN_PASS=
